# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bike_sharing
DB_PORT=5432

# App database URL inside Docker network
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/bike_sharing

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# GBFS Configuration
GBFS_BASE_URL=https://gbfs.lyft.com/gbfs/2.3/bkn/en
GBFS_LANGUAGE=en

# Environment
ENV=development

# Airflow Configuration
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_UID=1000

# FastAPI Downstream API Configuration
API_PORT=8000

# pgAdmin Configuration
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin